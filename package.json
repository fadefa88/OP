{
  "name": "op-main-manga-reader",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Archivio manga reader con deploy automatico su Cloudflare.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf:login": "wrangler login",
    "prepare:chapter": "node scripts/prepare-local-chapter.mjs",
    "upload:r2": "node scripts/upload-r2.mjs",
    "import:history:r2": "python scripts/import_history_to_r2.py --from-chapter 1 --to-chapter 1184 --webp-quality 90 --i-confirm-rights",
    "import:new:r2": "python scripts/import_new_chapter_to_r2.py --i-confirm-rights"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
