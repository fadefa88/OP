# Local one-time R2 import configuration.
# Copy to .env.local for your reference, or export these variables in PowerShell.
# Do not commit real secrets.

AUTHORIZED_MANGA_BASE_URL=https://your-authorized-source.example/path
# Optional custom pattern. Leave empty to use: {base_url}/volumi/volume{volume_padded}/{chapter_padded}/{page_padded}.{extension}
AUTHORIZED_MANGA_SOURCE_TEMPLATE=

CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET_NAME=op-reader-images
R2_PUBLIC_BASE_URL=https://static.lucahome.uk
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
I_CONFIRM_RIGHTS=true

# Image optimization. best-size keeps JPG/JPEG when WebP would be larger.
IMAGE_STRATEGY=best-size
WEBP_QUALITY=82
