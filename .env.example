# Authorized source. Required.
AUTHORIZED_MANGA_BASE_URL=https://your-authorized-source.example
# Optional URL template. Leave empty to use the default builder.
# AUTHORIZED_MANGA_SOURCE_TEMPLATE={base_url}/volumi/volume{volume_padded}/{chapter_padded}/{page_padded}.{extension}
I_CONFIRM_RIGHTS=true

# Cloudflare R2 / S3-compatible upload.
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET_NAME=op-reader-images
R2_PUBLIC_BASE_URL=https://static.lucahome.uk
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Import defaults.
LATEST_CHAPTER_TO_IMPORT=1185
IMAGE_EXTENSIONS=jpg,jpeg
IMAGE_STRATEGY=best-size
WEBP_QUALITY=82
MAX_PAGES=45
MIN_PAGES=3
STOP_AFTER_MISSING=3
IMPORT_TIMEOUT=15
IMPORT_DELAY=0.25
